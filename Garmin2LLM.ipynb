     "# ============================================================\n",
     "# 📅 CELLULE 3 — Sélection de la période\n",
     "# Choisis ton mode d'extraction\n",
     "# ============================================================\n",
     "\n",
     "from datetime import datetime, timedelta\n",
     "\n",
     "today = datetime.today()\n",
     "today_str = today.strftime(\"%Y-%m-%d\")\n",
     "\n",
     "print(\"=\"*55)\n",
     "print(\"     GARMIN EXTRACTOR — SANTÉ & ACTIVITÉS\")\n",
     "print(\"=\"*55)\n",
     "print(f\"  Aujourd'hui : {today_str}\")\n",
     "print()\n",
     "print(\"  0. Ultra rapide  → ce jour seulement\")\n",
     "print(\"  1. Rapide        → 7 derniers jours\")\n",
     "print(\"  2. Mensuel       → 30 derniers jours\")\n",
     "print(\"  3. Année         → depuis le 1er janvier\")\n",
     "print(\"  4. Personnalisée → tu choisis les dates\")\n",
     "print()\n",
     "\n",
     "choix = input(\"  Votre choix (0-4) : \").strip()\n",
     "\n",
     "if choix == \"0\":\n",
     "    start_date = today_str\n",
     "    end_date   = today_str\n",
     "elif choix == \"1\":\n",
     "    start_date = (today - timedelta(days=7)).strftime(\"%Y-%m-%d\")\n",
     "    end_date   = today_str\n",
     "elif choix == \"2\":\n",
     "    start_date = (today - timedelta(days=30)).strftime(\"%Y-%m-%d\")\n",
     "    end_date   = today_str\n",
     "elif choix == \"3\":\n",
     "    start_date = f\"{today.year}-01-01\"\n",
     "    end_date   = today_str\n",
     "elif choix == \"4\":\n",
     "    start_date = input(\"  Début (YYYY-MM-DD) : \").strip()\n",
     "    end_date_input = input(f\"  Fin   (YYYY-MM-DD, Entrée pour {today_str}) : \").strip()\n",
     "    end_date = end_date_input if end_date_input else today_str\n",
     "else:\n",
     "    print(\"❌ Choix invalide. Utilisation du mode 7 jours par défaut.\")\n",
     "    start_date = (today - timedelta(days=7)).strftime(\"%Y-%m-%d\")\n",
     "    end_date   = today_str\n",
     "\n",
     "print()\n",
     "print(f\"✅ Période sélectionnée : {start_date}  →  {end_date}\")\n",
     "print(\"📌 Lance la Cellule 4 pour extraire les données Santé.\")"
    ]

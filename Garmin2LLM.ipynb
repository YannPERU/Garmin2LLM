     "# ============================================================\n",
     "# 🐙 CELLULE 7 — Push vers GitHub (YannPERU/Garmin2LLM)\n",
     "# ============================================================\n",
     "import subprocess, time\n",
     "from google.colab import userdata, _message\n",
     "\n",
     "# --- Config ---\n",
     "GITHUB_TOKEN  = userdata.get('GITHUB_TOKEN')\n",
     "REPO          = \"YannPERU/Garmin2LLM\"\n",
     "BRANCH        = \"main\"\n",
     "NOTEBOOK_NAME = \"Garmin2LLM.ipynb\"\n",
     "REPO_DIR      = \"/tmp/Garmin2LLM\"\n",
     "COMMIT_MSG    = input(\"📝 Message de commit : \").strip()\n",
     "\n",
     "# --- Export du notebook via l'API Colab (méthode fiable) ---\n",
     "print(\"💾 Sauvegarde du notebook...\")\n",
     "_message.blocking_request('save_notebook', request='', timeout_sec=30)\n",
     "time.sleep(2)\n",
     "\n",
     "# Récupère le contenu binaire du notebook directement\n",
     "nb_content = _message.blocking_request(\n",
     "    'get_ipynb', request='', timeout_sec=30\n",
     ")\n",
     "\n",
     "# Écrit le fichier dans /tmp\n",
     "NOTEBOOK_TMP = f\"/tmp/{NOTEBOOK_NAME}\"\n",
     "import json\n",
     "with open(NOTEBOOK_TMP, 'w', encoding='utf-8') as f:\n",
     "    json.dump(nb_content, f, ensure_ascii=False, indent=1)\n",
     "\n",
     "print(f\"✅ Notebook exporté : {NOTEBOOK_TMP}\")\n",
     "\n",
     "# --- Clone, copie, push ---\n",
     "cmds = [\n",
     "    f\"rm -rf {REPO_DIR}\",\n",
     "    f\"git clone https://{GITHUB_TOKEN}@github.com/{REPO}.git {REPO_DIR}\",\n",
     "    f\"cp '{NOTEBOOK_TMP}' {REPO_DIR}/{NOTEBOOK_NAME}\",\n",
     "    f\"cd {REPO_DIR} && git config user.email 'colab@garmin2llm.io'\",\n",
     "    f\"cd {REPO_DIR} && git config user.name 'Colab Auto-Push'\",\n",
     "    f\"cd {REPO_DIR} && git add {NOTEBOOK_NAME}\",\n",
     "    f'cd {REPO_DIR} && git commit -m \"{COMMIT_MSG}\"',\n",
     "    f\"cd {REPO_DIR} && git push origin {BRANCH}\",\n",
     "]\n",
     "\n",
     "print(f\"\\n🚀 Push vers github.com/{REPO} ...\\n\")\n",
     "all_ok = True\n",
     "for cmd in cmds:\n",
     "    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)\n",
     "    if result.returncode != 0:\n",
     "        print(f\"❌ Erreur : {result.stderr.strip()}\")\n",
     "        all_ok = False\n",
     "        break\n",
     "\n",
     "if all_ok:\n",
     "    print(f\"\\n✅ Notebook publié sur GitHub !\")\n",
     "    print(f\"🔗 https://github.com/{REPO}/blob/{BRANCH}/{NOTEBOOK_NAME}\")\n",
     "    print(f\"\\n🔄 Lien Colab direct :\")\n",
     "    print(f\"   https://colab.research.google.com/github/{REPO}/blob/{BRANCH}/{NOTEBOOK_NAME}\")"

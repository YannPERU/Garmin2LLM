    "source": [
     "# ============================================================\n",
     "# 🏃 CELLULE 5 — Extraction des ACTIVITÉS\n",
     "# Récupère le détail complet de chaque séance\n",
     "# ============================================================\n",
     "\n",
     "import csv, json, time\n",
     "\n",
     "def process_activity_detail(api, activity_summary):\n",
     "    \"\"\"Récupère le détail complet avec sécurité sur les données absentes.\"\"\"\n",
     "    activity_id = activity_summary.get(\"activityId\")\n",
     "    if not activity_id:\n",
     "        return None\n",
     "    try:\n",
     "        full_data = api.get_activity(activity_id)\n",
     "        if not full_data or not isinstance(full_data, dict):\n",
     "            return None\n",
     "        row = {\n",
     "            \"activityName\":   full_data.get(\"activityName\"),\n",
     "            \"activityId\":     activity_id,\n",
     "            \"startTimeLocal\": full_data.get(\"summaryDTO\", {}).get(\"startTimeLocal\"),\n",
     "            \"description\":    full_data.get(\"description\"),\n",
     "        }\n",
     "        # Aplatissement du summaryDTO\n",
     "        for key, value in full_data.get(\"summaryDTO\", {}).items():\n",
     "            row[f\"sum_{key}\"] = value\n",
     "        # Splits (certaines activités n'en ont pas)\n",
     "        splits = full_data.get(\"splitSummaries\", [])\n",
     "        row[\"splitSummaries_json\"] = json.dumps(splits, ensure_ascii=False) if splits else \"[]\"\n",
     "        return row\n",
     "    except Exception as e:\n",
     "        print(f\"  ! Erreur sur l'ID {activity_id} : {e}\")\n",
     "        return None\n",
     "\n",
     "print(f\"🚀 Activités : {start_date} → {end_date}\")\n",
     "print(\"-\" * 50)\n",
     "\n",
     "activities = api.get_activities_by_date(start_date, end_date)\n",
     "print(f\"📊 {len(activities)} activité(s) trouvée(s).\")\n",
     "\n",
     "all_processed_rows = []\n",
     "for act in activities:\n",
     "    row_data = process_activity_detail(api, act)\n",
     "    if row_data:\n",
     "        all_processed_rows.append(row_data)\n",
     "        print(f\"  ✅ ID {act.get('activityId')} — {row_data.get('activityName', '?')} traité.\")\n",
     "    time.sleep(0.5)\n",
     "\n",
     "# --- Export CSV Activités ---\n",
     "activities_csv_path = f\"/tmp/activities_export_{start_date}.csv\"\n",
     "if all_processed_rows:\n",
     "    all_keys = set()\n",
     "    for r in all_processed_rows:\n",
     "        all_keys.update(r.keys())\n",
     "    keys_act = sorted(list(all_keys))\n",
     "\n",
     "    with open(activities_csv_path, 'w', encoding='utf-8-sig', newline='') as f:\n",
     "        writer = csv.DictWriter(f, fieldnames=keys_act, delimiter=';', restval='')\n",
     "        writer.writeheader()\n",
     "        writer.writerows(all_processed_rows)\n",
     "\n",
     "    # Préparation du texte activités\n",
     "    act_text  = f\"\\n\\n--- DÉTAILS COMPLETS ACTIVITÉS ({start_date} au {end_date}) ---\\n\"\n",
     "    act_text += \" ; \".join(keys_act) + \"\\n\"\n",
     "    for row in all_processed_rows:\n",
     "        vals = [str(row.get(k, \"\")).replace(\"\\n\", \" \").replace(\"\\r\", \"\") for k in keys_act]\n",
     "        act_text += \" ; \".join(vals) + \"\\n\"\n",
     "\n",
     "    # Fusion Santé + Activités dans une seule variable\n",
     "    global_full_text = global_health_text + act_text\n",
     "\n",
     "    print(f\"\\n✅ {len(all_processed_rows)} activité(s) extraite(s).\")\n",
     "    print(f\"📁 CSV prêt : {activities_csv_path}\")\n",
     "    print(\"📌 Lance la Cellule 6 pour télécharger tes fichiers.\")\n",
     "else:\n",
     "    global_full_text = global_health_text\n",
     "    print(\"\\nℹ️  Aucune activité valide trouvée sur cette période.\")"
    ]
   },

     "# ============================================================\n",
     "# 🏥 CELLULE 4 — Extraction des données SANTÉ\n",
     "# Récupère : Training Status, Bien-être, Sommeil, HRV, Preds\n",
     "# ============================================================\n",
     "\n",
     "import csv, time\n",
     "from datetime import datetime, timedelta\n",
     "\n",
     "def safe_div_60(value):\n",
     "    return round(value / 60, 0) if value and value != 0 else None\n",
     "\n",
     "def format_seconds(seconds):\n",
     "    if seconds is None: return \"-\"\n",
     "    return str(timedelta(seconds=int(seconds)))\n",
     "\n",
     "all_days_data = []\n",
     "s = datetime.strptime(start_date, \"%Y-%m-%d\")\n",
     "e = datetime.strptime(end_date,   \"%Y-%m-%d\")\n",
     "date_list = [(s + timedelta(days=x)).strftime(\"%Y-%m-%d\") for x in range((e - s).days + 1)]\n",
     "\n",
     "print(f\"🚀 Santé : {start_date} → {end_date} ({len(date_list)} jours)\")\n",
     "print(\"-\" * 50)\n",
     "\n",
     "for date in date_list:\n",
     "    day_entry = {\"Date\": date}\n",
     "    print(f\"⏳ {date} ...\", end=\" \")\n",
     "\n",
     "    try:\n",
     "        # A. TRAINING STATUS\n",
     "        try:\n",
     "            t_status = api.get_training_status(date)\n",
     "            if t_status:\n",
     "                balance_map = t_status.get('mostRecentTrainingLoadBalance', {}).get('metricsTrainingLoadBalanceDTOMap', {})\n",
     "                if balance_map:\n",
     "                    dev_id = next(iter(balance_map))\n",
     "                    bal = balance_map.get(dev_id, {})\n",
     "                    status_root = t_status.get('mostRecentTrainingStatus', {})\n",
     "                    latest_map  = status_root.get('latestTrainingStatusData', {})\n",
     "                    data  = latest_map.get(dev_id, {})\n",
     "                    acute = data.get('acuteTrainingLoadDTO', {})\n",
     "                    day_entry.update({\n",
     "                        \"Load_Base_Faible\":       bal.get('monthlyLoadAerobicLow'),\n",
     "                        \"Load_Base_Elevee\":       bal.get('monthlyLoadAerobicHigh'),\n",
     "                        \"Load_Anaerobie\":         bal.get('monthlyLoadAnaerobic'),\n",
     "                        \"Load_Feedback\":          bal.get('trainingBalanceFeedbackPhrase'),\n",
     "                        \"Target_Low_Min\":         bal.get('monthlyLoadAerobicLowTargetMin'),\n",
     "                        \"Target_Low_Max\":         bal.get('monthlyLoadAerobicLowTargetMax'),\n",
     "                        \"Target_High_Min\":        bal.get('monthlyLoadAerobicHighTargetMin'),\n",
     "                        \"Target_High_Max\":        bal.get('monthlyLoadAerobicHighTargetMax'),\n",
     "                        \"Target_Anaerobic_Min\":   bal.get('monthlyLoadAnaerobicTargetMin'),\n",
     "                        \"Target_Anaerobic_Max\":   bal.get('monthlyLoadAnaerobicTargetMax'),\n",
     "                        \"Charge_Aigue_Score\":     acute.get('dailyTrainingLoadAcute'),\n",
     "                        \"Charge_Chronique_Moy\":   acute.get('dailyTrainingLoadChronic'),\n",
     "                        \"Charge_Chronique_Min\":   acute.get('minTrainingLoadChronic'),\n",
     "                        \"Charge_Chronique_Max\":   acute.get('maxTrainingLoadChronic'),\n",
     "                        \"Ratio_ACWR\":             acute.get('dailyAcuteChronicWorkloadRatio'),\n",
     "                        \"ACWR_Percent\":           acute.get('acwrPercent'),\n",
     "                        \"ACWR_Statut\":            acute.get('acwrStatus'),\n",
     "                        \"Statut_Global\":          data.get('trainingStatusFeedbackPhrase'),\n",
     "                    })\n",
     "        except Exception as ex:\n",
     "            print(f\"(Training Status KO: {ex})\", end=\" \")\n",
     "\n",
     "        # B. BIEN-ÊTRE\n",
     "        summary = api.get_user_summary(date)\n",
     "        if summary:\n",
     "            day_entry.update({\n",
     "                \"Steps\":           summary.get('totalSteps'),\n",
     "                \"RestingHeartRate\": summary.get('restingHeartRate'),\n",
     "                \"Avg_Stress\":      summary.get('averageStressLevel'),\n",
     "                \"Calories_Active\": summary.get('activeKilocalories'),\n",
     "                \"BodyBatt_Recent\": summary.get('bodyBatteryMostRecentValue'),\n",
     "            })\n",
     "\n",
     "        # C. SOMMEIL\n",
     "        sleep = api.get_sleep_data(date)\n",
     "        if sleep and 'dailySleepDTO' in sleep:\n",
     "            dto    = sleep['dailySleepDTO']\n",
     "            scores = dto.get('sleepScores', {}).get('overall', {})\n",
     "            day_entry.update({\n",
     "                \"Sleep_Score\":        scores.get('value'),\n",
     "                \"Sleep_Qualitative\":  scores.get('qualifierKey'),\n",
     "                \"Sleep_Note\":         dto.get('sleepScoreFeedback'),\n",
     "                \"Sleep_Insight\":      dto.get('sleepScoreInsight'),\n",
     "                \"Personal_Note\":      dto.get('userNote'),\n",
     "                \"Sleep_min\":          round(dto.get('sleepTimeSeconds', 0) / 60, 0),\n",
     "                \"Sleep_deep_min\":     round(dto.get('deepSleepSeconds', 0) / 60, 0),\n",
     "                \"Sleep_light_min\":    round(dto.get('lightSleepSeconds', 0) / 60, 0),\n",
     "                \"Sleep_REM_min\":      round(dto.get('remSleepSeconds', 0) / 60, 0),\n",
     "                \"Sleep_awake_min\":    round(dto.get('awakeSleepSeconds', 0) / 60, 0),\n",
     "                \"Awake_count\":        dto.get('awakeCount'),\n",
     "                \"Agitation_Frequency\": sleep.get('restlessMomentsCount'),\n",
     "                \"Bed_time\":   datetime.fromtimestamp(dto['sleepStartTimestampGMT'] / 1000).strftime(\"%Y-%m-%d %H:%M:%S\") if dto.get('sleepStartTimestampGMT') else None,\n",
     "                \"WakeUp_time\": datetime.fromtimestamp(dto['sleepEndTimestampGMT']  / 1000).strftime(\"%Y-%m-%d %H:%M:%S\") if dto.get('sleepEndTimestampGMT')  else None,\n",
     "            })\n",
     "\n",
     "        # D. HRV / VFC\n",
     "        try:\n",
     "            hrv_data = api.get_hrv_data(date)\n",
     "            if hrv_data and 'hrvSummary' in hrv_data:\n",
     "                hrv_s = hrv_data['hrvSummary']\n",
     "                base  = hrv_s.get('baseline', {})\n",
     "                day_entry.update({\n",
     "                    \"HRV_lastNightAvg\":       hrv_s.get('lastNightAvg'),\n",
     "                    \"HRV_WeklyAvg\":           hrv_s.get('weeklyAvg'),\n",
     "                    \"HRV_Statut\":             hrv_s.get('status'),\n",
     "                    \"HRV_Pic_5min\":           hrv_s.get('lastNight5MinHigh'),\n",
     "                    \"HRV_Baseline_Min\":       base.get('balancedLow'),\n",
     "                    \"HRV_Baseline_Max\":       base.get('balancedUpper'),\n",
     "                    \"HRV_Baseline_Threshold\": base.get('lowUpper'),\n",
     "                    \"HRV_Position_Index\":     base.get('markerValue'),\n",
     "                })\n",
     "        except Exception as ex:\n",
     "            print(f\"(HRV KO: {ex})\", end=\" \")\n",
     "\n",
     "        # E. PRÉDICTIONS DE COURSE\n",
     "        try:\n",
     "            preds_list = api.get_race_predictions(date, date, api.display_name)\n",
     "            preds = preds_list[0] if isinstance(preds_list, list) and preds_list else preds_list\n",
     "            if isinstance(preds, dict):\n",
     "                day_entry[\"Pred_10k\"]      = format_seconds(preds.get('time10K'))\n",
     "                day_entry[\"Pred_Marathon\"] = format_seconds(preds.get('timeMarathon'))\n",
     "        except:\n",
     "            pass\n",
     "\n",
     "        all_days_data.append(day_entry)\n",
     "        print(\"✅\")\n",
     "\n",
     "    except Exception as err:\n",
     "        print(f\"\\n⚠️  Erreur le {date} : {err}\")\n",
     "\n",
     "    time.sleep(0.5)\n",
     "\n",
     "# --- Export CSV Santé ---\n",
     "health_csv_path = f\"/tmp/health_data_{start_date}.csv\"\n",
     "if all_days_data:\n",
     "    keys = list(all_days_data[0].keys())\n",
     "    with open(health_csv_path, 'w', encoding='utf-8-sig', newline='') as f:\n",
     "        writer = csv.DictWriter(f, fieldnames=keys, delimiter=';')\n",
     "        writer.writeheader()\n",
     "        writer.writerows(all_days_data)\n",
     "\n",
     "    # Préparation du texte pour le presse-papier (format compatible prompt IA)\n",
     "    health_text  = f\"--- FRAMEWORK SANTÉ COMPLET ({start_date} au {end_date}) ---\\n\"\n",
     "    health_text += \" ; \".join(keys) + \"\\n\"\n",
     "    for row in all_days_data:\n",
     "        vals = [str(row.get(k, \"\")).replace(\"\\n\", \" \").replace(\"\\r\", \"\").replace(\";\", \",\") for k in keys]\n",
     "        health_text += \" ; \".join(vals) + \"\\n\"\n",
     "\n",
     "    # Stockage en variable globale pour fusion avec activités\n",
     "    global_health_text = health_text\n",
     "\n",
     "    print(f\"\\n✅ {len(all_days_data)} jours extraits.\")\n",

    "source": [
     "# ============================================================\n",
     "# 🔐 CELLULE 2 — Connexion Garmin (gestion smart du login)\n",
     "#\n",
     "# MÉTHODE RECOMMANDÉE : Secrets Colab (zéro saisie à chaque fois)\n",
     "#   → Dans le menu gauche, clique sur 🔑 (Secrets)\n",
     "#   → Ajoute : GARMIN_EMAIL  et  GARMIN_PASSWORD\n",
     "#   → Active le switch \"Accès au notebook\"\n",
     "#\n",
     "# MÉTHODE FALLBACK : Si pas de secrets, saisie masquée interactive\n",
     "# ============================================================\n",
     "\n",
     "import getpass\n",
     "from pathlib import Path\n",
     "from garminconnect import Garmin\n",
     "\n",
     "# --- Récupération des identifiants (secrets Colab en priorité) ---\n",
     "def get_credentials():\n",
     "    \"\"\"Tente secrets Colab, sinon saisie interactive masquée.\"\"\"\n",
     "    email, password = None, None\n",
     "    try:\n",
     "        from google.colab import userdata\n",
     "        email = userdata.get('GARMIN_EMAIL')\n",
     "        password = userdata.get('GARMIN_PASSWORD')\n",
     "        if email and password:\n",
     "            print(\"✅ Identifiants chargés depuis les Secrets Colab.\")\n",
     "            return email, password\n",
     "    except Exception:\n",
     "        pass\n",
     "\n",
     "    # Fallback interactif\n",
     "    print(\"💡 Secrets Colab non trouvés → saisie manuelle (recommandé : configure les Secrets pour ne plus avoir à faire ça)\")\n",
     "    print(\"   (Menu gauche 🔑 > GARMIN_EMAIL + GARMIN_PASSWORD)\")\n",
     "    email = input(\"   📧 Email Garmin : \").strip()\n",
     "    password = getpass.getpass(\"   🔒 Mot de passe Garmin : \")\n",
     "    return email, password\n",
     "\n",
     "\n",
     "# --- Connexion avec gestion du token (évite le MFA répété) ---\n",
     "def get_api_client():\n",
     "    \"\"\"\n",
     "    Connexion intelligente :\n",
     "    1. Réutilise le token .garth si disponible en session (pas de MFA)\n",
     "    2. Sinon login complet avec email/mot de passe\n",
     "    3. Sauvegarde le token pour la suite de la session\n",
     "    \"\"\"\n",
     "    email, password = get_credentials()\n",
     "    client = Garmin(email, password)\n",
     "    token_path = Path(\"/tmp/.garth\")\n",
     "    token_path.mkdir(exist_ok=True)\n",
     "\n",
     "    try:\n",
     "        # Tentative de réutilisation du token existant\n",
     "        client.login(str(token_path))\n",
     "        print(\"🔄 Token existant réutilisé — pas besoin de re-saisir.\")\n",
     "    except Exception:\n",
     "        # Login complet (peut déclencher MFA si activé sur ton compte)\n",
     "        print(\"🔑 Connexion complète à Garmin Connect...\")\n",
     "        print(\"   ⚠️  Si Garmin demande un code MFA, vérifie tes emails/SMS Garmin.\")\n",
     "        try:\n",
     "            client.login()\n",
     "        except Exception as mfa_prompt:\n",
     "            # Garmin peut demander un code interactivement\n",
     "            print(f\"   Info login : {mfa_prompt}\")\n",
     "            mfa_code = input(\"   📱 Code MFA Garmin (laisse vide si non demandé) : \").strip()\n",
     "            if mfa_code:\n",
     "                client.login(mfa_token=mfa_code)\n",
     "        # Sauvegarde du token pour cette session\n",
     "        try:\n",
     "            client.garth.dump(str(token_path))\n",
     "            print(\"💾 Token sauvegardé — il sera réutilisé dans cette session.\")\n",
     "        except Exception as e:\n",
     "            print(f\"   (Info : token non sauvegardé : {e})\")\n",
     "\n",
     "    return client\n",
     "\n",
     "\n",
     "# Connexion\n",
     "print(\"🚀 Connexion à Garmin Connect...\")\n",
     "api = get_api_client()\n",
     "print(f\"\\n✅ Connecté ! Bienvenue {api.display_name}\")\n",
     "print(\"📌 Tu peux maintenant lancer la Cellule 3 pour choisir ta période.\")"
    ]
   },

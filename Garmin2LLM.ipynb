     "import subprocess, sys\n",
     "\n",
     "packages = [\"garminconnect\", \"python-dotenv\"]\n",
     "for pkg in packages:\n",
     "    subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", pkg])\n",
     "\n",
     "print(\"✅ Dépendances installées : garminconnect, python-dotenv\")\n",
     "print(\"📌 Tu peux maintenant lancer la Cellule 2 pour te connecter à Garmin.\")"
